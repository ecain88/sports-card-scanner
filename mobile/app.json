{
  "expo": {
    "name": "Card Scanner",
    "slug": "sports-card-scanner",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cardscanner.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to scan your sports cards",
        "NSPhotoLibraryUsageDescription": "Used to select card images from your library",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.cardscanner.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      [
        "expo-image-picker",
        {
          "photosPermission": "Used to select card images from your library"
        }
      ],
      "expo-secure-store"
    ],
    "scheme": "cardscanner",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ee834a23-e2a8-44ae-a19d-ed4ffd289216"
      }
    }
  }
}
